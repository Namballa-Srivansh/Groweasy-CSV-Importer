# Copy this file to .env and fill in your key

# Pick ONE provider and set its key. The code defaults to Anthropic.
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here

# Which model to use for extraction
AI_MODEL=claude-sonnet-4-6

# How many CSV rows to send to the AI per request
BATCH_SIZE=25

# Max retry attempts per failed batch
MAX_RETRIES=2

# Server port
PORT=4000

# Comma separated list of allowed origins for CORS (your deployed frontend URL)
CORS_ORIGIN=http://localhost:3000
